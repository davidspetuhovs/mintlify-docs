{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "OpenBat",
  "colors": {
    "primary": "#ffffff",
    "light": "#FFFFFF",
    "dark": "#FFFFFF"
  },
  "appearance": {
    "default": "dark",
    "strict": true
  },
  "background": {
    "decoration": "gradient"
  },
  "favicon": "/favicon.svg",
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Getting started",
            "pages": ["introduction", "quickstart"]
          },
          {
            "group": "Platform",
            "pages": [
              "guides/dashboard",
              "guides/conversations",
              "guides/deep-search",
              "guides/users-and-organizations",
              "guides/workflows"
            ]
          },
          {
            "group": "Configuration",
            "pages": [
              "guides/analysis-configuration",
              "guides/settings",
              "guides/team-management"
            ]
          }
        ]
      },
      {
        "tab": "SDK",
        "groups": [
          {
            "group": "Integration",
            "pages": [
              "sdk/installation",
              "sdk/vercel-ai-sdk",
              "sdk/typescript",
              "sdk/python",
              "sdk/rest-api"
            ]
          }
        ]
      },
      {
        "tab": "Concepts",
        "groups": [
          {
            "group": "How it works",
            "pages": [
              "concepts/sentiment-analysis",
              "concepts/behavior-detection",
              "concepts/revenue-signals"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "App",
          "href": "https://openbat.dev",
          "icon": "browser"
        }
      ]
    }
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:support@openbat.dev"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Dashboard",
      "href": "https://openbat.dev"
    }
  },
  "footer": {
    "socials": {
      "x": "https://x.com/openbatdev",
      "github": "https://github.com/openbat"
    }
  }
}