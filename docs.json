{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "OpenBat",
  "colors": {
    "primary": "#ffffff",
    "light": "#FFFFFF",
    "dark": "#FFFFFF"
  },
  "appearance": {
    "default": "dark",
    "strict": true
  },
  "background": {
    "decoration": "gradient"
  },
  "favicon": "/favicon.svg",
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navigation": {
    "tabs": [],
    "global": {
      "anchors": [
        {
          "anchor": "App",
          "href": "https://openbat.dev",
          "icon": "browser"
        }
      ]
    }
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:support@openbat.dev"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Dashboard",
      "href": "https://openbat.dev"
    }
  },
  "footer": {
    "socials": {
      "x": "https://x.com/openbatdev",
      "github": "https://github.com/openbat"
    }
  }
}