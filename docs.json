{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "OpenBat",
  "colors": {
    "primary": "#ffffff",
    "light": "#FFFFFF",
    "dark": "#FFFFFF"
  },
  "appearance": {
    "default": "dark",
    "strict": true
  },
  "background": {
    "decoration": "windows"
  },
  "favicon": "/favicon.svg",
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Getting started",
            "pages": [
              "guides/introduction",
              "guides/quickstart"
            ]
          },
          {
            "group": "Platform",
            "pages": [
              "guides/dashboard",
              "guides/conversations",
              "guides/deep-search",
              "guides/users-and-organizations",
              "guides/reports",
              "guides/workflows"
            ]
          },
          {
            "group": "Configuration",
            "pages": [
              "guides/analysis-configuration",
              "guides/translation",
              "guides/settings",
              "guides/team-management"
            ]
          }
        ]
      },
      {
        "tab": "SDK",
        "groups": [
          {
            "group": "Overview",
            "pages": [
              "sdk/introduction",
              "sdk/installation"
            ]
          },
          {
            "group": "Usage",
            "pages": [
              "sdk/recording-messages",
              "sdk/enriching-data",
              "sdk/vercel-ai-sdk"
            ]
          },
          {
            "group": "Reference",
            "pages": [
              "sdk/configuration",
              "sdk/error-handling"
            ]
          }
        ]
      },
      {
        "tab": "API reference",
        "groups": [
          {
            "group": "Overview",
            "pages": [
              "api-reference/introduction",
              "api-reference/authentication"
            ]
          },
          {
            "group": "Ingestion",
            "pages": [
              "api-reference/capture"
            ]
          },
          {
            "group": "Resources",
            "pages": [
              "api-reference/chatbots",
              "api-reference/conversations"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "App",
          "href": "https://openbat.dev",
          "icon": "browser"
        }
      ]
    }
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:support@openbat.dev"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Dashboard",
      "href": "https://openbat.dev"
    }
  },
  "footer": {
    "socials": {
      "x": "https://x.com/openbatdev",
      "github": "https://github.com/openbat"
    }
  }
}